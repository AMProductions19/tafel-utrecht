// ── Helpers ───────────────────────────────────────────────────────────────
const vibeLabel = v => ({ romantisch:'💑 Romantisch', casual:'😎 Casual', gezellig:'🎉 Gezellig', zakelijk:'💼 Zakelijk' }[v] || v);
const fallback  = 'https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=600&q=80';

// ── Filter ────────────────────────────────────────────────────────────────
function filtered() {
  return RESTAURANTS
    .filter(r => {
      if (state.cuisine && r.cuisine !== state.cuisine) return false;
      if (state.prijs   && r.prijs   !== state.prijs)   return false;
      if (state.vibe    && !r.vibe.includes(state.vibe)) return false;
      if (state.groep   && (state.groep < r.groep_min || state.groep > r.groep_max)) return false;
      if (state.zoek) {
        const q = state.zoek.toLowerCase();
        if (![r.naam, r.beschrijving, r.cuisine, r.buurt].join(' ').toLowerCase().includes(q)) return false;
      }
      return true;
    })
    .sort((a, b) => b.rating - a.rating);
}

// ── Render ────────────────────────────────────────────────────────────────
function render() {
  const list = filtered();
  const n = list.length;
  resultCount.textContent = `${n} restaurant${n !== 1 ? 's' : ''}`;
  headerCount.innerHTML   = `<strong>${n}</strong> gevonden`;
  resultTitle.textContent = [state.cuisine, state.prijs, state.vibe, state.zoek].some(Boolean) ? 'Gefilterde restaurants' : 'Alle restaurants';

  if (!list.length) {
    grid.innerHTML = `<div class="empty"><div class="emoji">🍽️</div><h3>Geen restaurants gevonden</h3><p>Pas je filters aan om meer opties te zien.</p></div>`;
    return;
  }

  grid.innerHTML = list.map((r, i) => `
    <article class="card" data-id="${r.id}" tabindex="0" style="animation-delay:${Math.min(i*55,400)}ms">
      <img class="card-img" src="${r.afbeelding}" alt="${r.naam}" loading="lazy" onerror="this.src='${fallback}'">
      <div class="card-body">
        <div class="card-top">
          <div class="card-naam">${r.naam}</div>
          <div class="prijs-badge">${r.prijs}</div>
        </div>
        <div class="card-tags">
          <span class="tag">${r.cuisine}</span>
          ${r.vibe.map(v => `<span class="tag vibe">${vibeLabel(v)}</span>`).join('')}
        </div>
        <p class="card-desc">${r.beschrijving}</p>
        <div class="card-icons">
          <span class="icon-pill">👥 ${r.groep_min}–${r.groep_max}p</span>
          ${r.terras ? '<span class="icon-pill">☀️ Terras</span>' : ''}
          ${r.reserveren ? '<span class="icon-pill">📋 Reserveren</span>' : ''}
        </div>
      </div>
      <div class="card-footer">
        <span class="card-adres">📍 ${r.buurt}</span>
        <div class="rating"><span class="star">★</span> ${r.rating}</div>
      </div>
    </article>
  `).join('');

  grid.querySelectorAll('.card').forEach(card => {
    const open = () => openModal(list.find(r => r.id === +card.dataset.id));
    card.addEventListener('click', open);
    card.addEventListener('keydown', e => e.key === 'Enter' && open());
  });
}

// ── Modal ─────────────────────────────────────────────────────────────────
function openModal(r) {
  document.getElementById('modal-img').src  = r.afbeelding || fallback;
  document.getElementById('modal-naam').textContent = r.naam;
  document.getElementById('modal-meta').innerHTML = `
    <span class="tag">${r.cuisine}</span>
    <span class="prijs-badge">${r.prijs}</span>
    ${r.vibe.map(v => `<span class="tag vibe">${vibeLabel(v)}</span>`).join('')}`;
  document.getElementById('modal-desc').textContent = r.beschrijving;
  document.getElementById('modal-details').innerHTML = `
    <div class="modal-detail">📍 <span><strong>${r.adres}, Utrecht</strong></span></div>
    <div class="modal-detail">👥 <span><strong>${r.groep_min}–${r.groep_max}</strong> personen</span></div>
    <div class="modal-detail">⭐ <span><strong>${r.rating}</strong> / 5.0</span></div>
    <div class="modal-detail">☀️ <span>Terras: <strong>${r.terras ? 'Ja' : 'Nee'}</strong></span></div>
    <div class="modal-detail">📋 <span>Reserveren: <strong>${r.reserveren ? 'verplicht' : 'niet nodig'}</strong></span></div>
    <div class="modal-detail">🏘 <span>Buurt: <strong>${r.buurt}</strong></span></div>`;
  document.getElementById('modal-actions').innerHTML = `
    ${r.website
      ? `<a class="btn-primary" href="${r.website}" target="_blank" rel="noopener">Naar website →</a>`
      : `<span class="btn-primary disabled">Geen website</span>`}
    <a class="btn-secondary" href="https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(r.naam+' '+r.adres+' Utrecht')}" target="_blank" rel="noopener">🗺 Maps</a>`;
  backdrop.classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  backdrop.classList.remove('open');
  document.body.style.overflow = '';
}

document.getElementById('modal-close').addEventListener('click', closeModal);
backdrop.addEventListener('click', e => e.target === backdrop && closeModal());
document.addEventListener('keydown', e => e.key === 'Escape' && closeModal());

// ── Filter events ─────────────────────────────────────────────────────────
selCuisine.addEventListener('change', () => { state.cuisine = selCuisine.value; render(); });
selPrijs.addEventListener('change',   () => { state.prijs   = selPrijs.value;   render(); });
selVibe.addEventListener('change',    () => { state.vibe    = selVibe.value;     render(); });
inputZoek.addEventListener('input',   () => { clearTimeout(debounce); debounce = setTimeout(() => { state.zoek = inputZoek.value.trim(); render(); }, 250); });

document.getElementById('groep-min').addEventListener('click', () => {
  if (state.groep > 0) state.groep = Math.max(0, state.groep - 1);
  groepVal.textContent = state.groep || 'Alle'; render();
});
document.getElementById('groep-plus').addEventListener('click', () => {
  state.groep = (state.groep || 1) + 1;
  groepVal.textContent = state.groep; render();
});
document.getElementById('reset').addEventListener('click', () => {
  state.cuisine = state.prijs = state.vibe = state.zoek = ''; state.groep = 0;
  selCuisine.value = selPrijs.value = selVibe.value = inputZoek.value = '';
  groepVal.textContent = 'Alle'; render();
});

// ── Init ──────────────────────────────────────────────────────────────────
render();
</script>


