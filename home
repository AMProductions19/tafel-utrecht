function initCarousel(el) {
  const slides = el.querySelectorAll('.rp-slide');
  const cdots  = el.querySelectorAll('.rp-cdot');
  const prev   = el.querySelector('.rp-carousel-btn.prev');
  const next   = el.querySelector('.rp-carousel-btn.next');
  if (slides.length <= 1) return;
  let cur = 0;

  function goTo(n) {
    slides[cur].classList.remove('active');
    cdots[cur] && cdots[cur].classList.remove('active');
    cur = (n + slides.length) % slides.length;
    slides[cur].classList.add('active');
    cdots[cur] && cdots[cur].classList.add('active');
  }

  prev && prev.addEventListener('click', e => { e.stopPropagation(); goTo(cur - 1); });
  next && next.addEventListener('click', e => { e.stopPropagation(); goTo(cur + 1); });

  // Touch swipe
  let tx = 0;
  el.addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, { passive: true });
  el.addEventListener('touchend',   e => {
    const dx = e.changedTouches[0].clientX - tx;
    if (Math.abs(dx) > 40) goTo(cur + (dx < 0 ? 1 : -1));
  }, { passive: true });
}

function backToApp() {
  resultsPage.style.display = 'none';
  document.querySelector('header').style.display = '';
  document.querySelector('.hero').style.display = '';
  document.querySelector('.filters-bar').style.display = '';
  document.querySelector('main').style.display = '';
  document.getElementById('kh-fab').style.display = '';
}

// Redo
redoBtn.addEventListener('click', () => {
  answers = {};
  currentStep = 0;
  results.classList.remove('visible');
  footer.style.display = 'flex';
  showStep(0);
});

// Filter alle matches (fallback — not used in new flow but kept for safety)
filterBtn.addEventListener('click', () => {
  closeWizard();
  const budget = answers[1];
  const gelegenheid = answers[0];
  const groep = parseInt(answers[2]) || 0;
  if (budget) { state.prijs = budget; document.getElementById('prijs').value = budget; }
  if (gelegenheid && ['romantisch','casual','gezellig','zakelijk'].includes(gelegenheid)) {
    state.vibe = gelegenheid; document.getElementById('vibe').value = gelegenheid;
  }
  if (groep) { state.groep = groep; document.getElementById('groep-val').textContent = groep; }

  render();
});

// Open/close
function closeWizard() {
  backdrop.classList.remove('open');
  document.body.style.overflow = '';
}

fab.addEventListener('click', () => {
  answers = {}; currentStep = 0;
  results.classList.remove('visible');
  footer.style.display = 'flex';
  showStep(0);
  backdrop.classList.add('open');
  document.body.style.overflow = 'hidden';
});

closeBtn.addEventListener('click', closeWizard);
backdrop.addEventListener('click', e => { if (e.target === backdrop) closeWizard(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeWizard(); });

})();
</script>

