  d.className = 'kh-dot';
  dots.appendChild(d);
}

function updateDots() {
  dots.querySelectorAll('.kh-dot').forEach((d, i) => {
    d.className = 'kh-dot' + (i === currentStep ? ' active' : i < currentStep ? ' done' : '');
  });
}

function updateProgress() {
  prog.style.width = ((currentStep / TOTAL_STEPS) * 100) + '%';
}

function showStep(n) {
  document.querySelectorAll('.kh-step').forEach(s => s.classList.remove('active'));
  const step = document.querySelector(`.kh-step[data-step="${n}"]`);
  if (step) step.classList.add('active');

  // Restore selection
  document.querySelectorAll(`.kh-opt[data-step="${n}"]`).forEach(opt => {
    opt.classList.toggle('selected', opt.dataset.val === answers[n]);
  });

  nextBtn.disabled = answers[n] === undefined;
  backBtn.style.visibility = n === 0 ? 'hidden' : 'visible';
  updateDots();
  updateProgress();
  headerSub.textContent = `Vraag ${n+1} van ${TOTAL_STEPS}`;
}

// Option click
document.addEventListener('click', e => {
  const opt = e.target.closest('.kh-opt');
  if (!opt) return;
  const step = parseInt(opt.dataset.step);
  if (isNaN(step)) return;

  document.querySelectorAll(`.kh-opt[data-step="${step}"]`).forEach(o => o.classList.remove('selected'));
  opt.classList.add('selected');
  answers[step] = opt.dataset.val;
  nextBtn.disabled = false;
});

// Next
nextBtn.addEventListener('click', () => {
  if (currentStep < TOTAL_STEPS - 1) {
    currentStep++;
    showStep(currentStep);
  } else {
    showResults();
  }
});

// Back
backBtn.addEventListener('click', () => {
  if (currentStep > 0) { currentStep--; showStep(currentStep); }
});

// ── Scoring ──────────────────────────────────
function scoreRestaurant(r) {
  let score = 0;
  const maxScore = 100;

  // 1. Gelegenheid / vibe (25 punten)
  const gelegenheid = answers[0];
  if (gelegenheid) {
    const vibeMap = {
      romantisch: ['romantisch'], zakelijk: ['zakelijk'],
      gezellig: ['gezellig'], casual: ['casual'],
      familie: ['casual', 'gezellig'], solo: ['casual']
    };
    const wanted = vibeMap[gelegenheid] || [];
    const match = wanted.filter(v => r.vibe && r.vibe.includes(v)).length;
    score += (match / Math.max(wanted.length, 1)) * 25;
  } else { score += 12; }

  // 2. Budget (20 punten)
  const budget = answers[1];
  if (budget) {
    if (r.prijs === budget) score += 20;
    else if (Math.abs('€€€'.indexOf(r.prijs) - '€€€'.indexOf(budget)) === 2) score += 5;
    else score += 10;
  } else { score += 10; }

  // 3. Groepsgrootte (15 punten)
  const groep = parseInt(answers[2]);
  if (groep) {
    if (groep >= r.groep_min && groep <= r.groep_max) score += 15;
    else if (groep < r.groep_min) score += 3;
    else score += 8;
  } else { score += 8; }

  // 4. Cuisine (15 punten)
  const cuisinePref = answers[3];
  if (cuisinePref && cuisinePref !== 'any') {
    const wanted = cuisinePref.split('|');
    if (wanted.some(c => r.cuisine && r.cuisine.includes(c))) score += 15;
  } else { score += 8; }

  // 5. Terras (5 punten)
  const terras = answers[4];
  if (terras === 'yes' && r.terras) score += 5;
  else if (terras === 'no') score += 5;
  else if (terras === 'yes' && !r.terras) score += 0;
  else score += 3;

  // 6. Spontaan/reserveren (5 punten)
  const spontaan = answers[5];
  if (spontaan === 'spontaan' && !r.reserveren) score += 5;
  else if (spontaan === 'reserveren' && r.reserveren) score += 5;
  else if (!spontaan) score += 3;
  else score += 2;

  // 7. Kwaliteit vs sfeer (10 punten)
  const kwal = answers[6];
  const highEnd = ['€€€'].includes(r.prijs) && r.rating >= 4.5;
  if (kwal === 'kwaliteit' && highEnd) score += 10;
  else if (kwal === 'sfeer' && r.vibe && r.vibe.length >= 2) score += 10;
  else if (kwal === 'balans') score += 7;
  else score += 4;

  // 8. Moment — lunch hints (5 punten)
  const moment = answers[7];
  const isLunchVriendelijk = r.cuisine && ['Lunch & Brunch','Grand Café','Europees-Modern'].includes(r.cuisine);
  if (moment === 'lunch' && isLunchVriendelijk) score += 5;
  else if (moment === 'diner' && !isLunchVriendelijk) score += 5;
  else score += 3;

  // Bonus: hoge rating
  score += (r.rating - 4.0) * 5;

  return Math.min(Math.round(score), 100);
}

