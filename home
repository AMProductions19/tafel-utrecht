<script>
// ══════════════════════════════════════════════
//  KEUZEHULP WIZARD
// ══════════════════════════════════════════════
(function() {

const TOTAL_STEPS = 8;
let currentStep = 0;
let answers = {}; // step → value

// DOM
const fab       = document.getElementById('kh-fab');
const backdrop  = document.getElementById('kh-backdrop');
