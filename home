// ── Matchredenen genereren ────────────────────────────────────────────
function getMatchReasons(r, score) {
  const reasons = [];
  const gelegenheid = answers[0];
  const budget = answers[1];
  const groep = parseInt(answers[2]);
  const cuisinePref = answers[3];
  const terras = answers[4];
  const spontaan = answers[5];
  const kwal = answers[6];
  const moment = answers[7];

  const vibeMap = { romantisch:'romantisch', zakelijk:'zakelijk', gezellig:'gezellig', casual:'casual', familie:'gezellig', solo:'casual' };
  if (gelegenheid && r.vibe && r.vibe.includes(vibeMap[gelegenheid])) {
    const labels = { romantisch:'Perfecte romantische sfeer', zakelijk:'Geschikt voor zakelijk', gezellig:'Ideaal voor een vriendengroep', casual:'Lekker casual en ongedwongen', familie:'Gezinsvriendelijke omgeving', solo:'Prima plek om solo te eten' };
    reasons.push('✓ ' + (labels[gelegenheid] || 'Passende vibe'));
  }
  if (budget && r.prijs === budget) reasons.push('✓ Past precies binnen je budget (' + budget + ')');
  if (groep && groep >= r.groep_min && groep <= r.groep_max) reasons.push('✓ Geschikt voor jouw groepsgrootte');
  if (cuisinePref && cuisinePref !== 'any') {
    const wanted = cuisinePref.split('|');
    if (wanted.some(c => r.cuisine && r.cuisine.includes(c))) reasons.push('✓ ' + r.cuisine + ' keuken — jouw voorkeur');
  }
  if (terras === 'yes' && r.terras) reasons.push('✓ Heeft een terras');
  if (spontaan === 'spontaan' && !r.reserveren) reasons.push('✓ Geen reservering nodig, gewoon binnenlopen');
  if (spontaan === 'reserveren' && r.reserveren) reasons.push('✓ Reserveren mogelijk');
  if (kwal === 'kwaliteit' && r.rating >= 4.5) reasons.push('✓ Hoge kwaliteit (rating ' + r.rating + ')');
  if (kwal === 'sfeer' && r.vibe && r.vibe.length >= 2) reasons.push('✓ Uitstekende sfeer en beleving');
  if (r.rating >= 4.7) reasons.push('✓ Uitstekend beoordeeld (' + r.rating + '/5)');
  if (r.website) reasons.push('✓ Website & reservering beschikbaar');
  if (reasons.length === 0) reasons.push('✓ Goede algemene match op basis van jouw profiel');
  return reasons.slice(0, 4);
}

