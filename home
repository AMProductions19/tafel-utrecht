// ── Vul cuisine dropdown dynamisch ────────────────────────────────────────
const cuisines = [...new Set(RESTAURANTS.map(r => r.cuisine))].sort();
const selCuisine = document.getElementById('cuisine');
cuisines.forEach(c => {
  const o = document.createElement('option');
  o.value = c; o.textContent = c;
  selCuisine.appendChild(o);
});

// ── State ─────────────────────────────────────────────────────────────────
const state = { cuisine:'', prijs:'', vibe:'', groep:0, zoek:'' };
let debounce = null;

// ── DOM refs ──────────────────────────────────────────────────────────────
const grid        = document.getElementById('restaurant-grid');
const resultTitle = document.getElementById('result-title');
const resultCount = document.getElementById('result-count');
const headerCount = document.getElementById('header-count');
const selPrijs    = document.getElementById('prijs');
const selVibe     = document.getElementById('vibe');
const inputZoek   = document.getElementById('zoek');
const groepVal    = document.getElementById('groep-val');
